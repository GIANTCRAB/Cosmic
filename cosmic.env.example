# Copy this file to cosmic.env and fill in your values.
# cosmic.env is gitignored and loaded by docker-compose via env_file.
# Values set here override their counterparts in config.yaml.

# External (WAN) IPv4 address clients connect to. Overrides server.HOST in config.yaml.
HOST=

# Admin account password (plaintext). Overrides the seeded default ("admin"); the server bcrypt-hashes it on startup.
# Re-applied on every restart while set, so clear it to manage the admin password manually.
ADMIN_PASSWORD=
